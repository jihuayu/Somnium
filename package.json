{
  "name": "somnium",
  "version": "1.3.0",
  "homepage": "https://blog.jihuayu.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jihuayu/somnium.git"
  },
  "scripts": {
    "dev": "pnpm run notion-react:build && next dev --webpack",
    "build": "pnpm run notion-react:build && next build --webpack",
    "start": "next start",
    "test": "node --import tsx --test tests/**/*.test.ts packages/*/tests/**/*.test.ts",
    "lint": "eslint .",
    "postbuild": "next-sitemap --config config/next-sitemap.config.js",
    "notion-react:build": "pnpm --filter @jihuayu/notion-react build",
    "notion-react:storybook": "storybook dev -p 6006 -c packages/notion-react/.storybook --disable-telemetry",
    "notion-react:storybook:build": "storybook build -c packages/notion-react/.storybook -o packages/notion-react/storybook-static --disable-telemetry"
  },
  "dependencies": {
    "@jihuayu/notion-react": "workspace:*",
    "@vercel/og": "^0.9.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.19",
    "feed": "^4.2.2",
    "image-size": "^2.0.2",
    "katex": "^0.16.33",
    "mermaid": "^11.12.3",
    "next": "^16.1.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.4.49",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "browserslist": {
    "production": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 111",
      "safari >= 16.4",
      "ios_saf >= 16.4"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "pnpm@10.11.0"
}
