{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": ".cache/tsconfig.build.tsbuildinfo",
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": [
      "astro/client"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@jihuayu/notion-react": [
        "./packages/notion-react/src/index.ts"
      ],
      "@jihuayu/notion-react/normalize": [
        "./packages/notion-react/src/normalize.ts"
      ],
      "@jihuayu/notion-react/rss": [
        "./packages/notion-react/src/rss.ts"
      ],
      "@jihuayu/notion-react/og": [
        "./packages/notion-react/src/og.ts"
      ]
    },
    "plugins": []
  },
  "include": [
    ".astro/types.d.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.astro"
  ],
  "exclude": [
    "node_modules",
    "app",
    ".next"
  ]
}
